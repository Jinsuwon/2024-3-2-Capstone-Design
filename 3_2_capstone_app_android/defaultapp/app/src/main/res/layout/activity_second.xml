<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@drawable/background_image13">


<!-- Arduino 1 블록 -->

    <!-- Arduino 2 블록 -->

    <!-- Arduino 3 블록 -->

    <TextView
        android:id="@+id/arduino1TextView"
        android:layout_width="180dp"
        android:layout_height="130dp"
        android:layout_marginStart="155dp"
        android:layout_marginTop="0dp"
        android:background="#FFCCCC"
        android:gravity="center"
        android:text="변기 1"
        android:textColor="#000000"
        android:textSize="27sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/arduino2TextView"
        android:layout_width="180dp"
        android:layout_height="130dp"
        android:layout_marginStart="155dp"
        android:layout_marginTop="16dp"
        android:background="#CCCCFF"
        android:gravity="center"
        android:text="변기 2"
        android:textColor="#000000"
        android:textSize="27sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/arduino1TextView" />

    <TextView
        android:id="@+id/arduino3TextView"
        android:layout_width="180dp"
        android:layout_height="130dp"
        android:layout_marginStart="155dp"
        android:layout_marginTop="18dp"
        android:background="#CCFFCC"
        android:gravity="center"
        android:text="변기 3"
        android:textColor="#000000"
        android:textSize="27sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/arduino2TextView" />


    <!-- 문 이미지 -->

</androidx.constraintlayout.widget.ConstraintLayout>
